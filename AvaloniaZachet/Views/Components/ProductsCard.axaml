<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AvaloniaZachet.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaZachet.Views.Components.ProductsCard"
             x:DataType="vm:ProductCardViewModel">
    
    <Border Background="#D2DFFF" BorderThickness="1" BorderBrush="#355CBD">
        <StackPanel Spacing="8" Margin="20">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding ProductType}" FontSize="22" FontWeight="SemiBold" Foreground="#355CBD"/>
                    <TextBlock Text=" | " FontSize="22" FontWeight="SemiBold" Foreground="#355CBD"/>
                    <TextBlock Text="{Binding Name}" FontSize="22" FontWeight="SemiBold" Foreground="#355CBD"/>
                </StackPanel>
                
                <TextBlock Grid.Column="1"
                           Text="{Binding Time, StringFormat='Время изготовления: {0:0.##}'}"
                           FontSize="18" FontWeight="SemiBold" Foreground="#355CBD"/>
                
            </Grid>
            
            <TextBlock Text="{Binding Article, StringFormat='Артикул: {0}'}" FontWeight="SemiBold" Foreground="#355CBD"/>
            <TextBlock Text="{Binding MinCostPartner, StringFormat='Минимальная стоимость для партнера: {0}'}"
                       FontWeight="SemiBold" Foreground="#355CBD"/>
            <TextBlock Text="{Binding MaterialType, StringFormat='Основной материал: {0}'}"
                       FontWeight="SemiBold" Foreground="#355CBD"/>
            
        </StackPanel>
    </Border>
    
</UserControl>
